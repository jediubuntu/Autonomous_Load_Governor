# Copy this file to .env and fill in real values locally.
# Never commit .env.

# Required: OpenAI-compatible chat completions API.
# You may use ALG_LLM_API_KEY or OPENAI_API_KEY.
ALG_LLM_API_KEY=
ALG_LLM_BASE_URL=https://api.openai.com/v1
ALG_LLM_MODEL=
ALG_LLM_MAX_RETRIES=3
ALG_LLM_RETRY_SECONDS=10

# Controller defaults.
ALG_TARGET_URL=http://127.0.0.1:8000
ALG_INITIAL_USERS=50
ALG_MIN_USERS=1
ALG_MAX_USERS=1000
ALG_STEP_USERS=50
ALG_SPAWN_RATE=10
ALG_INTERVAL_SECONDS=30
ALG_MAX_INTERVALS=20
ALG_REPORT_EVERY_SECONDS=60

# Decision thresholds.
ALG_LATENCY_THRESHOLD_MS=500
ALG_ERROR_RATE_THRESHOLD=0.02
ALG_CPU_THRESHOLD_PERCENT=80
ALG_STABLE_INTERVALS=2
ALG_KNEE_LATENCY_MULTIPLIER=2.5

# Locust workload controls.
WORK_MS=20
FAIL_PCT=0
SLEEP_SECONDS=1
